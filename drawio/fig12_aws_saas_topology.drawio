<mxfile host="draw.io" type="device">
  <diagram id="fig12" name="Fig 12 — AWS SaaS Deployment Topology">
    <mxGraphModel dx="900" dy="500" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="500" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- AWS Region Zone -->
        <mxCell id="z_aws" value="&lt;b&gt;AWS Region (ap-southeast-2)&lt;/b&gt;" style="rounded=1;arcSize=18;shadow=0;fontFamily=Helvetica Neue;fontColor=#32ADE6;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=none;strokeColor=#32ADE6;dashed=1;dashPattern=8 4;verticalAlign=top;fontSize=12;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="530" height="340" as="geometry"/>
        </mxCell>

        <!-- Corporate Network Zone -->
        <mxCell id="z_corp" value="&lt;b&gt;Corporate Network&lt;/b&gt;" style="rounded=1;arcSize=18;shadow=0;fontFamily=Helvetica Neue;fontColor=#8E8E93;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=none;strokeColor=#D1D1D6;dashed=1;dashPattern=8 4;verticalAlign=top;fontSize=12;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="580" y="20" width="300" height="340" as="geometry"/>
        </mxCell>

        <!-- Inside AWS -->
        <mxCell id="alb" value="&lt;b&gt;ALB / NLB&lt;/b&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#E0F2FB;strokeColor=#32ADE6;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="110" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="defender" value="&lt;b&gt;Cequence Defender&lt;/b&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#E5F0FF;strokeColor=#007AFF;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="190" y="60" width="150" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="analytics" value="&lt;b&gt;Cequence Analytics&lt;/b&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#E5F0FF;strokeColor=#007AFF;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="380" y="60" width="150" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="secrets" value="&lt;b&gt;AWS Secrets Manager&lt;/b&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#F3E5FA;strokeColor=#AF52DE;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="150" width="160" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="cw" value="&lt;b&gt;CloudWatch&lt;/b&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#E5F6FE;strokeColor=#5AC8FA;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="240" y="150" width="120" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="certstore" value="&lt;b&gt;Cert Store&lt;/b&gt;" style="shape=cylinder3;rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#E5F6FE;strokeColor=#5AC8FA;size=12;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="400" y="140" width="110" height="60" as="geometry"/>
        </mxCell>

        <!-- Inside Corporate Network -->
        <mxCell id="dcerts" value="&lt;b&gt;DCERTS Portal / API&lt;/b&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#E5F0FF;strokeColor=#007AFF;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="610" y="60" width="150" height="45" as="geometry"/>
        </mxCell>
        <mxCell id="eca" value="&lt;b&gt;Enterprise CA&lt;/b&gt;&lt;br/&gt;&lt;i&gt;DigiCert&lt;/i&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#E8F9ED;strokeColor=#34C759;strokeWidth=2;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="610" y="150" width="150" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="saasops" value="&lt;b&gt;Cequence SaaS Ops&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Vendor-managed&lt;/i&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#F1ECE6;strokeColor=#A2845E;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="610" y="250" width="150" height="55" as="geometry"/>
        </mxCell>

        <!-- External: API Consumers -->
        <mxCell id="apicons" value="&lt;b&gt;API Consumers&lt;/b&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#F2F2F7;strokeColor=#D1D1D6;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="120" height="45" as="geometry"/>
        </mxCell>

        <!-- Connectors with step numbers -->
        <!-- 1: API Consumers -> ALB -->
        <mxCell id="c1" value="&lt;b&gt;1&lt;/b&gt; HTTPS" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=1;arcSize=10;strokeColor=#007AFF;strokeWidth=2;fontFamily=Helvetica Neue;fontColor=#1D1D1F;fontSize=10;endArrow=blockThin;endSize=6;html=1;" edge="1" source="apicons" target="alb" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- 2: ALB -> Defender -->
        <mxCell id="c2" value="&lt;b&gt;2&lt;/b&gt; Inspect" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=1;arcSize=10;strokeColor=#007AFF;strokeWidth=2;fontFamily=Helvetica Neue;fontColor=#1D1D1F;fontSize=10;endArrow=blockThin;endSize=6;html=1;" edge="1" source="alb" target="defender" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- 3: Defender -> Analytics -->
        <mxCell id="c3" value="&lt;b&gt;3&lt;/b&gt; Telemetry" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=1;arcSize=10;strokeColor=#C7C7CC;strokeWidth=1.5;fontFamily=Helvetica Neue;fontColor=#1D1D1F;fontSize=10;endArrow=blockThin;endSize=6;html=1;" edge="1" source="defender" target="analytics" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- 4: Cert Store -> Defender -->
        <mxCell id="c4" value="&lt;b&gt;4&lt;/b&gt; TLS cert" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=1;arcSize=10;strokeColor=#C7C7CC;strokeWidth=1.5;fontFamily=Helvetica Neue;fontColor=#1D1D1F;fontSize=10;endArrow=blockThin;endSize=6;html=1;" edge="1" source="certstore" target="defender" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- 5: DCERTS -> Cert Store (provision) -->
        <mxCell id="c5" value="&lt;b&gt;5&lt;/b&gt; Provision" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=1;arcSize=10;strokeColor=#007AFF;strokeWidth=2;fontFamily=Helvetica Neue;fontColor=#1D1D1F;fontSize=10;endArrow=blockThin;endSize=6;html=1;" edge="1" source="dcerts" target="certstore" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- DCERTS -> Enterprise CA -->
        <mxCell id="c_ca" value="Issue" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=1;arcSize=10;strokeColor=#C7C7CC;strokeWidth=1.5;fontFamily=Helvetica Neue;fontColor=#1D1D1F;fontSize=10;endArrow=blockThin;endSize=6;html=1;" edge="1" source="dcerts" target="eca" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- SaaS Ops -> Defender (manage) -->
        <mxCell id="c_sops" value="Manage" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=1;arcSize=10;strokeColor=#A2845E;strokeWidth=1.5;fontFamily=Helvetica Neue;fontColor=#1D1D1F;fontSize=10;endArrow=blockThin;endSize=6;html=1;" edge="1" source="saasops" target="defender" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="560" y="277"/>
              <mxPoint x="560" y="82"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- Secrets Manager -> Defender -->
        <mxCell id="c_sec" value="Secrets" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=1;arcSize=10;strokeColor=#AF52DE;strokeWidth=1.5;fontFamily=Helvetica Neue;fontColor=#1D1D1F;fontSize=10;endArrow=blockThin;endSize=6;html=1;" edge="1" source="secrets" target="defender" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- CloudWatch -> Analytics -->
        <mxCell id="c_cw" value="Logs" style="edgeStyle=orthogonalEdgeStyle;curved=1;rounded=1;arcSize=10;strokeColor=#5AC8FA;strokeWidth=1.5;fontFamily=Helvetica Neue;fontColor=#1D1D1F;fontSize=10;endArrow=blockThin;endSize=6;html=1;" edge="1" source="analytics" target="cw" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Legend -->
        <mxCell id="leg12" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br/&gt;Blue = Lifecycle&lt;br/&gt;Green = Terminal&lt;br/&gt;Violet = Evidence&lt;br/&gt;Cyan = DataStore&lt;br/&gt;Brown = Vendor" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#F2F2F7;strokeColor=#D1D1D6;fontSize=9;align=left;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="780" y="380" width="110" height="110" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
