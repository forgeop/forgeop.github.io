        <mxCell id="r1c3" value="&lt;b&gt;Kubernetes Secret&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;tls.crt / tls.key&lt;/font&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#F3E5FA;strokeColor=#AF52DE;strokeWidth=1.5;html=1;whiteSpace=wrap;align=center;" vertex="1" parent="1">
          <mxGeometry x="420" y="66" width="180" height="56" as="geometry"/>
        </mxCell>

        <!-- ROW 2 -->
        <mxCell id="r2c1" value="&lt;b&gt;Secrets Control&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Vault / ASM&lt;/font&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#F3E5FA;strokeColor=#AF52DE;strokeWidth=1.5;html=1;whiteSpace=wrap;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="150" width="180" height="56" as="geometry"/>
