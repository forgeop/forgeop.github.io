          <mxGeometry x="220" y="150" width="180" height="56" as="geometry"/>
        </mxCell>

        <mxCell id="r2c3" value="&lt;b&gt;Authoritative DNS&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Nameserver&lt;/font&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#E5F6FE;strokeColor=#5AC8FA;strokeWidth=1.5;html=1;whiteSpace=wrap;align=center;" vertex="1" parent="1">
          <mxGeometry x="420" y="150" width="180" height="56" as="geometry"/>
        </mxCell>

        <!-- ROW 3 (centered) -->
        <mxCell id="r3c1" value="&lt;b&gt;Ingress / Gateway&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Cequence Defender&lt;/font&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#E5F0FF;strokeColor=#007AFF;strokeWidth=1.5;html=1;whiteSpace=wrap;align=center;" vertex="1" parent="1">
          <mxGeometry x="220" y="234" width="180" height="56" as="geometry"/>
        </mxCell>

        <!-- ARROWS Row 1 flow -->
        <mxCell id="a1" style="strokeColor=#C7C7CC;strokeWidth=1.5;endArrow=blockThin;endSize=6;rounded=1;arcSize=10;curved=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;html=1;" edge="1" source="r1c1" target="r1c2" parent="1">
