        </mxCell>
        <mxCell id="a2" style="strokeColor=#C7C7CC;strokeWidth=1.5;endArrow=blockThin;endSize=6;rounded=1;arcSize=10;curved=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;html=1;" edge="1" source="r1c2" target="r1c3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Secrets Control feeds ClusterIssuer -->
        <mxCell id="a3" style="strokeColor=#AF52DE;strokeWidth=1.5;dashed=1;endArrow=blockThin;endSize=6;rounded=1;arcSize=10;curved=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;html=1;" edge="1" source="r2c1" target="r1c1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- ClusterIssuer triggers DNS-01 Solver -->
        <mxCell id="a4" style="strokeColor=#007AFF;strokeWidth=2;endArrow=blockThin;endSize=6;rounded=1;arcSize=10;curved=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;html=1;" edge="1" source="r1c1" target="r2c2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- DNS-01 Solver to Auth DNS -->
        <mxCell id="a5" style="strokeColor=#C7C7CC;strokeWidth=1.5;endArrow=blockThin;endSize=6;rounded=1;arcSize=10;curved=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;html=1;" edge="1" source="r2c2" target="r2c3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- K8s Secret to Ingress -->
        <mxCell id="a6" style="strokeColor=#007AFF;strokeWidth=2;endArrow=blockThin;endSize=6;rounded=1;arcSize=10;curved=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;html=1;" edge="1" source="r1c3" target="r3c1" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Secrets Control to K8s Secret -->
        <mxCell id="a7" style="strokeColor=#AF52DE;strokeWidth=1.5;dashed=1;endArrow=blockThin;endSize=6;rounded=1;arcSize=10;curved=1;exitX=1;exitY=0;exitDx=0;exitDy=0;entryX=0;entryY=1;entryDx=0;entryDy=0;html=1;" edge="1" source="r2c1" target="r1c3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- CUSTODY NOTE -->
        <mxCell id="note1" value="&lt;i&gt;Secrets control plane holds EAB / TSIG keys; K8s Secrets are delivery-only caches&lt;/i&gt;" style="rounded=1;arcSize=18;shadow=0;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=6;spacingBottom=6;spacingLeft=14;spacingRight=14;fillColor=#F2F2F7;strokeColor=#D1D1D6;strokeWidth=1;fontSize=10;html=1;whiteSpace=wrap;align=center;" vertex="1" parent="1">
