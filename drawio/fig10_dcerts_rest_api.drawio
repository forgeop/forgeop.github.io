        <!-- Legend -->
        <mxCell id="leg10" value="&lt;b&gt;Legend&lt;/b&gt;&lt;br/&gt;Blue = Lifecycle&lt;br/&gt;Green = Terminal&lt;br/&gt;Orange = Gate&lt;br/&gt;Purple = Process&lt;br/&gt;Cyan = DataStore&lt;br/&gt;Violet = Evidence&lt;br/&gt;Brown = Vendor" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#F2F2F7;strokeColor=#D1D1D6;fontSize=9;align=left;html=1;whiteSpace=wrap;" vertex="1" parent="1">
