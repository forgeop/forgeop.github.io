        <!-- Bottom Stores -->
        <mxCell id="16" value="&lt;b&gt;Inventory&lt;/b&gt;" style="shape=cylinder3;rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#E5F6FE;strokeColor=#5AC8FA;size=12;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="230" y="230" width="100" height="60" as="geometry"/>
