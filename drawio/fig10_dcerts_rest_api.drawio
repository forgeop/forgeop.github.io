<mxfile host="draw.io" type="device">
  <diagram id="fig10" name="Fig 10 — DCERTS REST API Integration">
    <mxGraphModel dx="820" dy="400" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="820" pageHeight="400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Left Actors -->
        <mxCell id="10" value="&lt;b&gt;Cequence SaaS Ops&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Vendor-managed&lt;/i&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#F1ECE6;strokeColor=#A2845E;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="40" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="&lt;b&gt;OKAPI Ops&lt;/b&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#EEEEFF;strokeColor=#5856D6;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="20" y="130" width="140" height="50" as="geometry"/>
