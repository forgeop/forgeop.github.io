        <!-- Enterprise CA (DigiCert) -->
        <mxCell id="15" value="&lt;b&gt;Enterprise CA&lt;/b&gt;&lt;br/&gt;&lt;i&gt;DigiCert&lt;/i&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#E8F9ED;strokeColor=#34C759;strokeWidth=2;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="700" y="40" width="100" height="60" as="geometry"/>
