        <!-- Center: Automation Client -->
        <mxCell id="12" value="&lt;b&gt;Automation Client&lt;/b&gt;&lt;br/&gt;&lt;i&gt;Key Gen + CSR&lt;/i&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#EEEEFF;strokeColor=#5856D6;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="260" y="80" width="150" height="60" as="geometry"/>
        </mxCell>

        <!-- Right: DCERTS REST API -->
        <mxCell id="13" value="&lt;b&gt;DCERTS REST API&lt;/b&gt;" style="rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#E5F0FF;strokeColor=#007AFF;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="510" y="40" width="140" height="50" as="geometry"/>
        </mxCell>

        <!-- PKI R/A Diamond -->
        <mxCell id="14" value="&lt;b&gt;PKI R/A&lt;/b&gt;" style="rhombus;rounded=1;arcSize=18;shadow=1;shadowColor=#2C2C3A;shadowOpacity=25;shadowOffsetX=0;shadowOffsetY=3;fontFamily=Helvetica Neue;fontColor=#1D1D1F;spacing=6;spacingTop=10;spacingBottom=10;spacingLeft=14;spacingRight=14;fillColor=#FFF4E5;strokeColor=#FF9500;html=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="600" y="115" width="80" height="65" as="geometry"/>
